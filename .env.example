# Kapso — https://docs.kapso.ai/docs/introduction
# Use your team Kapso project’s sandbox WhatsApp config: same sandbox number for all,
# but each developer adds their own phone in the dashboard to test from their WhatsApp.
KAPSO_API_KEY=
KAPSO_PHONE_NUMBER_ID=
KAPSO_API_URL=https://api.kapso.ai

# Webhook verification (GET challenge from Kapso / Meta)
KAPSO_VERIFY_TOKEN=choose-a-random-string

# Optional: HMAC verification for POST webhooks (from Kapso dashboard)
KAPSO_WEBHOOK_SECRET=

# App
ENVIRONMENT=development
PORT=8080

# --- champeta: Stripe + Flow payment demo ---
# Setup order:
#   1) Create a Stripe test account, grab sk_test_... -> STRIPE_SECRET_KEY
#   2) Run: python -m app.services.flow_setup  (uses KAPSO_PHONE_NUMBER_ID)
#   3) Paste the printed flow_id -> KAPSO_FLOW_ID
#   4) Restart uvicorn

STRIPE_SECRET_KEY=
STRIPE_CURRENCY=usd

KAPSO_FLOW_ID=

# Anthropic (Claude) — used by the dynamic agents (Google ADK + LiteLLM)
ANTHROPIC_API_KEY=

# Google Gemini fallback — used if Claude is temporarily overloaded
GEMINI_API_KEY=
GEMINI_FALLBACK_MODEL=gemini/gemini-2.5-flash
