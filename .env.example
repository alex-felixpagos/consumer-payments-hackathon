# Kapso — https://docs.kapso.ai/docs/introduction
# Use your team Kapso project’s sandbox WhatsApp config: same sandbox number for all,
# but each developer adds their own phone in the dashboard to test from their WhatsApp.
KAPSO_API_KEY=
KAPSO_PHONE_NUMBER_ID=
KAPSO_API_URL=https://api.kapso.ai

# Webhook verification (GET challenge from Kapso / Meta)
KAPSO_VERIFY_TOKEN=choose-a-random-string

# Optional: HMAC verification for POST webhooks (from Kapso dashboard)
KAPSO_WEBHOOK_SECRET=

# App
ENVIRONMENT=development
PORT=8080
# Public HTTPS URL for generated media links, for example your ngrok URL.
PUBLIC_BASE_URL=

# --- champeta: Stripe + Flow payment demo ---
# Setup order:
#   1) Create a Stripe test account, grab sk_test_... -> STRIPE_SECRET_KEY
#   2) Run: python -m app.services.flow_setup  (uses KAPSO_PHONE_NUMBER_ID)
#   3) Paste the printed flow_id -> KAPSO_FLOW_ID
#   4) Restart uvicorn

STRIPE_SECRET_KEY=
STRIPE_CURRENCY=usd
# Public URL that opens the React payment page. For phone testing, expose the
# frontend with ngrok or deploy it, then paste the HTTPS base URL here.
PUBLIC_PAYMENT_BASE_URL=http://localhost:5173
# Default ticket price (in the smallest currency unit) when a movie provider
# does not return a price. Used when persisting a pending booking.
TICKET_DEFAULT_AMOUNT_CENTS=100

KAPSO_FLOW_ID=

# Anthropic (Claude) — used by the dynamic agents (Google ADK + LiteLLM)
ANTHROPIC_API_KEY=

# Google Gemini fallback — used if Claude is temporarily overloaded
GEMINI_API_KEY=
GEMINI_FALLBACK_MODEL=gemini/gemini-2.5-flash

# MovieGlu — https://developer.movieglu.com/
# Required for app.skills.search_movie_showtimes live API calls.
MOVIEGLU_CLIENT=
MOVIEGLU_API_KEY=
MOVIEGLU_AUTHORIZATION=
MOVIEGLU_TERRITORY=US
MOVIEGLU_API_VERSION=v200
MOVIEGLU_API_URL=https://api-gate2.movieglu.com
MOVIEGLU_TIMEOUT_SECONDS=8

# --- champeta: buy-ticket (Procinal) ---
# Self-contained ticket-buying service that calls Procinal's API end-to-end.
# Independent of the Stripe pay-in flow above.
#
# Account: use Diego's pre-registered Procinal account (ask in #cp-hackathon
# for credentials) or sign up at procinal.com.co with your own.
#
# Card requirements: a regular bank-issued credit card (Visa/MC). Fintech /
# virtual cards (DolarApp, Lithic, etc.) are blocked at issuer level — they
# return ED-024 "Tarjeta no permitida por la empresa".
PROCINAL_BASE_URL=https://apinew.procinal.com.co
PROCINAL_DOCUMENTO=
PROCINAL_CLAVE=
PROCINAL_EMAIL=
PROCINAL_CARD_NUMBER=
PROCINAL_CARD_EXP_MONTH=
PROCINAL_CARD_EXP_YEAR=
PROCINAL_CARD_CVC=
